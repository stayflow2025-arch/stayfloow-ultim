
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "languagePreference": { "type": "string" },
        "currencyPreference": { "type": "string" },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["id", "email", "firstName", "lastName"]
    },
    "PartnerListing": {
      "title": "PartnerListing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "category": { "type": "string", "enum": ["accommodation", "car_rental", "circuit"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "details": { "type": "object" },
        "location": { "type": "object" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "category", "status", "price"]
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "partnerId": { "type": "string" },
        "listingId": { "type": "string" },
        "itemName": { "type": "string" },
        "itemType": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "totalPrice": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "partnerId", "listingId", "startDate", "totalPrice"]
    },
    "Conversation": {
      "title": "Conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "bookingId": { "type": "string" },
        "listingId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "User profiles" },
    "/listings/{listingId}": { "schema": { "$ref": "#/backend/entities/PartnerListing" }, "description": "Public listings" },
    "/bookings/{bookingId}": { "schema": { "$ref": "#/backend/entities/Booking" }, "description": "Reservations" },
    "/conversations/{convId}": { "schema": { "$ref": "#/backend/entities/Conversation" }, "description": "Messaging threads" },
    "/conversations/{convId}/messages/{msgId}": { "schema": { "type": "object" }, "description": "Individual messages" }
  }
}

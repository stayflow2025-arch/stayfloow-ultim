rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. FONCTIONS DE SÉCURITÉ MAÎTRES
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" || 
        (request.auth.token.email != null && request.auth.token.email.lower() == "stayflow2025@gmail.com") ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "kiosque.du.passage@gmail.com")
      );
    }

    // 2. ACCÈS PRIORITAIRE ADMINISTRATEUR (GOD MODE)
    // On autorise explicitement read (get+list) et write pour l'admin partout
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 3. RÈGLES UTILISATEURS STANDARDS
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      // Autoriser explicitement le listing pour les admins (couvert par le God Mode mais renforcé ici)
      allow list: if isAdmin();
      
      // Accès individuel pour les utilisateurs concernés
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid ||
        isAdmin()
      );
    }

    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == partnerId || isAdmin());
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /conversations/{convId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid]) ||
          isAdmin()
        );
      }
    }
  }
}
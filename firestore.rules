rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" ||
        (request.auth.token.email != null && 
         request.auth.token.email.lower() in ['stayflow2025@gmail.com', 'kiosque.du.passage@gmail.com'])
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      // Les admins peuvent lister toutes les réservations sans restriction
      allow list: if isAdmin();
      // Lecture individuelle pour les admins ou les parties concernées
      allow get: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.partnerId == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.partnerId == request.auth.uid));
    }

    match /partners/{partnerId} {
      allow read, write: if isOwner(partnerId) || isAdmin();
    }

    match /payments/{payId} {
      allow read, write: if isAdmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /conversations/{convId} {
      // Autorise explicitement la liste globale pour les admins
      allow list: if isAdmin();
      // Lecture individuelle
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      allow write: if isSignedIn();
      
      match /messages/{msgId} {
        allow list, get: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid]));
        allow write: if isSignedIn();
      }
    }
  }
}
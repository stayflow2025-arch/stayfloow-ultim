rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "Kb7jQGxp4pf1cjdfbMwz4HnujQi2" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" ||
        request.auth.uid == "CChLqb7OxdbbSpjNRKMAt2vJNa12" ||
        request.auth.uid == "3rixbVLeMaUARuODthz3ds80WeS2" ||
        request.auth.uid == "dqUISCFanPajTlrvC23iAXTr4BI2" ||
        request.auth.uid == "cJujCOjr1nRe4YSBZ9FY3WLLvO93"
      );
    }

    // --- ACCÈS ADMINISTRATEUR GLOBAL (PRIORITÉ MAXIMALE) ---
    // Cette règle autorise les administrateurs à tout lire et tout écrire partout.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- RÈGLES SPÉCIFIQUES PAR COLLECTION ---

    // USERS
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // LISTINGS
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS
    match /bookings/{bookingId} {
      // Autoriser le listage pour les admins (via la règle globale) et les utilisateurs connectés
      allow list: if isSignedIn();
      // Lecture/Ecriture spécifique pour les propriétaires ou admins
      allow get, update, delete: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      ));
      allow create: if isSignedIn();
    }

    // PARTNERS
    match /partners/{partnerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == partnerId || isAdmin());
    }

    // CONVERSATIONS
    match /conversations/{convId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // SETTINGS & SITE CONFIG
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // MAIL (TRIGGER EMAIL EXTENSION)
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // STRIPE (CUSTOMERS & PRODUCTS)
    match /customers/{uid}/{any=**} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /products/{id} {
      allow read: if true;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. FONCTIONS DE SÉCURITÉ MAÎTRES
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Vérification Admin ultra-robuste (UID prioritaire + Emails)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" || 
        (request.auth.token.email != null && request.auth.token.email.lower() == "stayflow2025@gmail.com") ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "kiosque.du.passage@gmail.com")
      );
    }

    // 2. ACCÈS MAÎTRE PRIORITAIRE (GOD MODE)
    // Cette règle prévaut sur toutes les autres : l'admin peut tout lister, lire et écrire partout.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 3. RÈGLES UTILISATEURS STANDARDS (Pour les clients et partenaires)
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
    }

    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && request.auth.uid == partnerId;
    }

    match /settings/{doc} {
      allow read: if true;
    }

    match /conversations/{convId} {
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid])
        );
      }
    }
  }
}
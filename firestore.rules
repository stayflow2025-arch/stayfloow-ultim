
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. ADMIN STRICT (seuls ces deux comptes ont accès total)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    // 2. UTILISATEUR CONNECTÉ
    function isSignedIn() {
      return request.auth != null;
    }

    // ACCÈS TOTAL POUR ADMIN SEULEMENT
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 3. RÈGLES SPÉCIFIQUES PAR COLLECTION
    
    // Users : chacun son propre profil
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Listings : lecture publique, écriture par propriétaire ou admin
    match /listings/{listingId} {
      allow read: if true; 
      allow create: if true; // Permettre la soumission par les invités
      allow update, delete: if isSignedIn() && (
        isAdmin() || resource.data.ownerId == request.auth.uid
      );
    }

    // Bookings : Accès filtré par userId ou partnerId
    match /bookings/{bookingId} {
      // Pour le listage (useCollection), Firestore exige que la requête soit filtrée
      allow list: if isSignedIn() && (
        isAdmin() || 
        request.query.filters.userId == request.auth.uid || 
        request.query.filters.partnerId == request.auth.uid
      );
      // Pour la lecture directe d'un document
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
      allow create: if true; // Autoriser la création même en mode invité
      allow update, delete: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.partnerId == request.auth.uid));
    }

    // Conversations : lecture/écriture seulement par les participants ou admin
    match /conversations/{convId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid in resource.data.participants
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      
      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid])
        );
      }
    }

    // Partners : chacun son profil partenaire
    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && (
        isAdmin() || request.auth.uid == partnerId
      );
    }

    // Settings : lecture publique, écriture admin seulement
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

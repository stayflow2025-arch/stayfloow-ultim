rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    // Vérification robuste du rôle administrateur (UID + Emails autorisés)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "stayflow2025@gmail.com") ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "kiosque.du.passage@gmail.com")
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.partnerId == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.partnerId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read, write: if isOwner(partnerId) || isAdmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /conversations/{convId} {
      // Un admin peut tout voir, un participant ne voit que ses discussions
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      match /messages/{msgId} {
        // L'admin ou un participant peut lire et créer
        allow read, create: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid]));
      }
    }
  }
}
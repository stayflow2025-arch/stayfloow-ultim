
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" ||
        request.auth.uid == "Kb7jQGxp4pf1cjdfbMwz4HnujQi2" ||
        request.auth.uid == "CChLqb7OxdbbSpjNRKMAt2vJNa12" ||
        request.auth.uid == "3rixbVLeMaUARuODthz3ds80WeS2"
      );
    }

    // ADMIN accès total prioritaire
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // USERS - Lecture/Écriture par le propriétaire
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
    }

    // LISTINGS - Lecture publique, création connectée
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // BOOKINGS - Gestion des réservations
    match /bookings/{bookingId} {
      // autoriser les dashboards à lister les réservations (Correction demandée)
      allow list: if isSignedIn();

      // lecture d'une réservation spécifique
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        isAdmin()
      );

      // création réservation
      allow create: if isSignedIn(); 

      // modification réservation
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // PARTNERS - Profils professionnels
    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == partnerId || isAdmin());
    }

    // CONVERSATIONS - Messagerie sécurisée
    match /conversations/{convId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        request.auth.uid in resource.data.participants || 
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // SETTINGS - Configuration site
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // STRIPE EXTENSION - Sessions de paiement
    match /customers/{uid}/checkout_sessions/{id} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // MAIL EXTENSION - Envoi d'emails
    match /mail/{mailId} {
      allow create: if isSignedIn();
    }
  }
}

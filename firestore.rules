rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.keys().contains('email') && request.auth.token.email == "stayflow2025@gmail.com") ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    // USERS : Accès restreint au propriétaire ou admin
    match /users/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // PARTNERS : Accès restreint au partenaire ou admin
    match /partners/{partnerId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }

    // LISTINGS : Lecture publique, création pour tous (Onboarding), modification propriétaire
    match /listings/{listingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS : Séparation GET et LIST pour éviter les erreurs dashboard
    match /bookings/{bookingId} {
      // lecture d'un booking spécifique : propriétaire, partenaire ou admin uniquement
      allow get: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      // autoriser la liste pour les dashboards (le filtrage réel se fait par la query .where())
      allow list: if isSignedIn();

      // création réservation (autorise le mode invité lors de la validation du paiement)
      allow create: if true;

      // modification : propriétaire, partenaire ou admin
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      // suppression seulement admin
      allow delete: if isAdmin();
    }

    // CONVERSATIONS : Séparation GET et LIST
    match /conversations/{convId} {
      // autoriser la liste pour charger les dashboards
      allow list: if isSignedIn();
      
      // lecture d'une conversation spécifique : uniquement les participants ou admin
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      // création conversation
      allow create: if isSignedIn();
      
      // modification
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // SETTINGS & CONFIG
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // STRIPE EXTENSION PATHS
    match /customers/{uid}/checkout_sessions/{id} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // ADMIN PRIORITAIRE (Accès global)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" ||
        request.auth.uid == "Kb7jQGxp4pf1cjdfbMwz4HnujQi2" ||
        request.auth.uid == "CChLqb7OxdbbSpjNRKMAt2vJNa12"
      );
    }

    // USERS : Accès restreint au propriétaire ou admin
    match /users/{userId} {
      // Autoriser la liste pour l'admin ou le dash local (filtrage par UID)
      allow list: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Lecture individuelle
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Création
      allow create: if isSignedIn();
      // Mise à jour
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Suppression réservée à l'admin
      allow delete: if isAdmin();
    }

    // PARTNERS : Accès restreint au partenaire ou admin
    match /partners/{partnerId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }

    // LISTINGS : Lecture publique, création pour tous (Onboarding), modification propriétaire
    match /listings/{listingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS : Autoriser LIST pour charger les tableaux de bord
    match /bookings/{bookingId} {
      // Liste autorisée pour les membres (la sécurité réelle est dans la query .where('userId', '=='))
      allow list: if isSignedIn();

      // Lecture d'un booking spécifique : propriétaire, partenaire ou admin uniquement
      allow get: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      // Création réservation autorisée pour tous (Guest booking mode)
      allow create: if true;

      // Modification : propriétaire, partenaire ou admin
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      // Suppression seulement admin
      allow delete: if isAdmin();
    }

    // CONVERSATIONS : Autoriser LIST pour charger les messageries
    match /conversations/{convId} {
      allow list: if isSignedIn();
      
      // Lecture d'une conversation spécifique : uniquement les participants ou admin
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      // Création conversation
      allow create: if isSignedIn();
      
      // Modification
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // SETTINGS & CONFIG
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // STRIPE EXTENSION PATHS
    match /customers/{uid}/checkout_sessions/{id} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // ADMIN PRIORITAIRE (Accès global)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
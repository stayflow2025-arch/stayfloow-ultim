
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. DÉTECTION ADMIN MAÎTRE (STRICTE)
    // Seul stayflow2025@gmail.com peut accéder au mode administrateur.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ACCÈS PRIORITAIRE ADMIN : Pas de restriction pour le compte maître
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 2. RÈGLES UTILISATEURS STANDARDS
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow list: if isAdmin(); 
      allow get: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
    }

    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == partnerId || isAdmin());
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /conversations/{convId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      
      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid])
        );
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ADMIN STRICT (seulement ces deux comptes ont accès total)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    // UTILISATEUR CONNECTÉ
    function isSignedIn() {
      return request.auth != null;
    }

    // ADMIN ACCÈS TOTAL (Prioritaire)
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // USERS : Accès restreint au propriétaire
    match /users/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // PARTNERS : Accès restreint au partenaire
    match /partners/{partnerId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }

    // LISTINGS : Lecture publique, modification propriétaire
    match /listings/{listingId} {
      allow read: if true;
      allow create: if true; // Autorise les soumissions anonymes (onboarding)
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS : lecture/écriture seulement par l’utilisateur ou le partenaire concerné
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );
      
      // On autorise la création publique pour le mode invité (Guest Booking)
      // Mais si l'utilisateur est connecté, on vérifie son identité
      allow create: if (request.auth == null || request.resource.data.userId == request.auth.uid)
        && request.resource.data.listingId is string;

      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );

      allow delete: if isAdmin();
    }

    // CONVERSATIONS : Accès restreint aux participants
    match /conversations/{convId} {
      allow read, update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.participants
      );
      
      allow create: if isSignedIn();

      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
        );
      }
    }

    // SETTINGS & CONFIG
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
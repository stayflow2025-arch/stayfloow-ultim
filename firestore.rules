rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ADMIN STRICT (seulement ces deux comptes ont accès total)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    // UTILISATEUR CONNECTÉ
    function isSignedIn() {
      return request.auth != null;
    }

    // ADMIN ACCÈS TOTAL (Prioritaire)
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // USERS : Accès restreint au propriétaire
    match /users/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // PARTNERS : Accès restreint au partenaire
    match /partners/{partnerId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }

    // LISTINGS : Lecture publique, modification propriétaire
    match /listings/{listingId} {
      allow read: if true;
      allow create: if true; // Autorise les soumissions anonymes (onboarding)
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS : Correction des permissions list/get pour les dashboards
    match /bookings/{bookingId} {
      // lecture d'un booking spécifique
      allow get: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );

      // autoriser la liste pour les dashboards (les filtres dans le code assurent l'isolation)
      allow list: if isSignedIn();

      // création réservation
      allow create: if isSignedIn();

      // modification
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );

      // suppression seulement admin
      allow delete: if isAdmin();
    }

    // CONVERSATIONS : Accès restreint aux participants
    match /conversations/{convId} {
      allow get: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.participants
      );
      
      // autoriser la liste pour les dashboards
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.participants
      );

      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
        );
      }
    }

    // SETTINGS & CONFIG
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
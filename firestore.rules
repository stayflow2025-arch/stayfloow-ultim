rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. FONCTIONS DE SÉCURITÉ PARTAGÉES
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" || 
        request.auth.token.email.lower() == "stayflow2025@gmail.com" ||
        request.auth.token.email.lower() == "kiosque.du.passage@gmail.com"
      );
    }

    // 2. ACCÈS MAÎTRE (ADMINISTRATION)
    // Règle globale pour l'administrateur - s'applique à tous les documents
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 3. RÈGLES UTILISATEURS STANDARDS (NON-ADMINS)
    
    match /users/{userId} {
      // Les admins ont accès via la règle globale. Les utilisateurs accèdent à leur propre profil.
      allow read, write: if request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      // Autorise explicitement le listing global (list) pour les admins
      // ainsi que la lecture individuelle (get) pour les parties concernées.
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));
    }

    match /partners/{partnerId} {
      allow read, write: if request.auth.uid == partnerId;
    }

    match /settings/{doc} {
      allow read: if true;
    }

    match /conversations/{convId} {
      // Les admins peuvent lister toutes les conversations pour le support.
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      match /messages/{msgId} {
        allow read, create: if isAdmin() || (isSignedIn() && 
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid]));
      }
    }
  }
}